# HMAC secret for QR token verification (must match ezqrin-server's QR_HMAC_SECRET)
# REQUIRED - minimum 32 characters
QR_HMAC_SECRET=CHANGE-ME-use-openssl-rand-base64-32-to-generate

# Event information displayed on the boarding pass
# REQUIRED - all fields must be set
EVENT_NAME=Your Event Name
EVENT_VENUE=Venue Name
EVENT_DATE=YYYY.MM.DD
EVENT_ADDRESS=Full address here
EVENT_MAPS_URL=https://maps.google.com/?q=your+venue
